package ai.tegmentum.wasmtime4j.validation;

import static org.junit.jupiter.api.Assertions.*;

import ai.tegmentum.wasmtime4j.Engine;
import ai.tegmentum.wasmtime4j.Export;
import ai.tegmentum.wasmtime4j.Function;
import ai.tegmentum.wasmtime4j.Instance;
import ai.tegmentum.wasmtime4j.Memory;
import ai.tegmentum.wasmtime4j.Module;
import ai.tegmentum.wasmtime4j.Store;
import ai.tegmentum.wasmtime4j.WasmFeature;
import ai.tegmentum.wasmtime4j.WasmValue;
import ai.tegmentum.wasmtime4j.exception.WasmException;
import java.io.IOException;
import java.io.InputStream;
import java.nio.ByteBuffer;
import java.util.ArrayList;
import java.util.List;
import java.util.logging.Logger;
import org.junit.jupiter.api.AfterEach;
import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.DisplayName;
import org.junit.jupiter.api.Test;
import org.junit.jupiter.api.TestInfo;

/**
 * Comprehensive WebAssembly validation tests covering core functionality across both JNI and Panama
 * implementations.
 *
 * <p>This test class validates basic WebAssembly operations including engine creation, module
 * compilation, instance creation, function calling, memory operations, and resource management.
 * Tests are designed to work with standard JUnit 5 and Maven Surefire integration.
 *
 * @since 1.0.0
 */
@DisplayName("WebAssembly Core Validation Tests")
public final class WebAssemblyValidationTests {

  private static final Logger logger = Logger.getLogger(WebAssemblyValidationTests.class.getName());

  private Engine engine;
  private Store store;
  private List<AutoCloseable> resources;

  @BeforeEach
  void setUp(final TestInfo testInfo) throws WasmException {
    logger.info("Setting up test: " + testInfo.getDisplayName());
    resources = new ArrayList<>();

    // Create engine with default configuration
    engine = Engine.create();
    resources.add(engine);

    // Create store
    store = engine.createStore();
    resources.add(store);

    logger.info("Test setup completed successfully");
  }

  @AfterEach
  void tearDown(final TestInfo testInfo) {
    logger.info("Cleaning up test: " + testInfo.getDisplayName());

    // Close all resources in reverse order
    for (int i = resources.size() - 1; i >= 0; i--) {
      try {
        final AutoCloseable resource = resources.get(i);
        if (resource != null) {
          resource.close();
        }
      } catch (final Exception e) {
        logger.warning("Failed to close resource during cleanup: " + e.getMessage());
      }
    }

    resources.clear();
    store = null;
    engine = null;

    logger.info("Test cleanup completed");
  }

  @Test
  @DisplayName("Engine Creation and Basic Properties")
  void testEngineCreation() {
    assertNotNull(engine, "Engine should be created successfully");
    assertTrue(engine.isValid(), "Engine should be valid after creation");
    assertNotNull(engine.getConfig(), "Engine should have configuration");
    assertTrue(engine.getReferenceCount() > 0, "Engine should have positive reference count");

    logger.info("Engine creation validation passed");
  }

  @Test
  @DisplayName("Store Creation and Management")
  void testStoreCreation() throws WasmException {
    assertNotNull(store, "Store should be created successfully");

    // Test creating additional stores
    final Store store2 = engine.createStore();
    resources.add(store2);
    assertNotNull(store2, "Additional store should be created successfully");

    // Test store with custom data
    final String customData = "test-data";
    final Store store3 = engine.createStore(customData);
    resources.add(store3);
    assertNotNull(store3, "Store with custom data should be created successfully");

    logger.info("Store creation validation passed");
  }

  @Test
  @DisplayName("Module Compilation from Simple WAT")
  void testModuleCompilation() throws WasmException, IOException {
    final byte[] wasmBytes = loadSimpleWasmModule();
    assertNotNull(wasmBytes, "WASM bytes should be loaded");
    assertTrue(wasmBytes.length > 0, "WASM bytes should not be empty");

    final Module module = engine.compileModule(wasmBytes);
    resources.add(module);

    assertNotNull(module, "Module should be compiled successfully");
    assertTrue(module.isValid(), "Module should be valid after compilation");

    logger.info(
        "Module compilation validation passed with module size: " + wasmBytes.length + " bytes");
  }

  @Test
  @DisplayName("Instance Creation and Export Access")
  void testInstanceCreation() throws WasmException, IOException {
    final byte[] wasmBytes = loadSimpleWasmModule();
    final Module module = engine.compileModule(wasmBytes);
    resources.add(module);

    final Instance instance = module.instantiate(store);
    resources.add(instance);

    assertNotNull(instance, "Instance should be created successfully");

    // Verify exports
    final List<Export> exports = instance.getExports();
    assertNotNull(exports, "Instance should have exports");
    assertFalse(exports.isEmpty(), "Instance should have at least one export");

    // Look for the 'add' function export
    final Export addExport =
        exports.stream().filter(export -> "add".equals(export.getName())).findFirst().orElse(null);

    assertNotNull(addExport, "Instance should export 'add' function");
    assertEquals(Export.Type.FUNCTION, addExport.getType(), "Export should be a function");

    logger.info("Instance creation validation passed with " + exports.size() + " exports");
  }

  @Test
  @DisplayName("Function Invocation and Parameter Passing")
  void testFunctionInvocation() throws WasmException, IOException {
    final byte[] wasmBytes = loadSimpleWasmModule();
    final Module module = engine.compileModule(wasmBytes);
    resources.add(module);

    final Instance instance = module.instantiate(store);
    resources.add(instance);

    // Get the 'add' function
    final Function addFunction = instance.getFunction("add");
    assertNotNull(addFunction, "Should be able to get 'add' function");

    // Test function call with valid parameters
    final WasmValue[] params = {WasmValue.createI32(5), WasmValue.createI32(3)};
    final WasmValue[] results = addFunction.call(params);

    assertNotNull(results, "Function call should return results");
    assertEquals(1, results.length, "Function should return exactly one result");
    assertEquals(8, results[0].getI32(), "Function should correctly add 5 + 3 = 8");

    logger.info("Function invocation validation passed: 5 + 3 = " + results[0].getI32());
  }

  @Test
  @DisplayName("Memory Operations and Access")
  void testMemoryOperations() throws WasmException, IOException {
    // Create a module with memory for testing
    final byte[] wasmBytesWithMemory = loadMemoryWasmModule();
    final Module module = engine.compileModule(wasmBytesWithMemory);
    resources.add(module);

    final Instance instance = module.instantiate(store);
    resources.add(instance);

    // Check if instance has memory
    final Memory memory = instance.getMemory("memory");
    if (memory != null) {
      assertNotNull(memory, "Should be able to access memory");
      assertTrue(memory.getSize() > 0, "Memory should have positive size");

      // Test basic memory operations
      final ByteBuffer buffer = memory.getBuffer();
      assertNotNull(buffer, "Should be able to get memory buffer");

      logger.info(
          "Memory operations validation passed with memory size: " + memory.getSize() + " pages");
    } else {
      logger.info("No memory export found in module, skipping memory-specific tests");
    }
  }

  @Test
  @DisplayName("Global Variable Access")
  void testGlobalAccess() throws WasmException, IOException {
    final byte[] wasmBytes = loadGlobalWasmModule();
    final Module module = engine.compileModule(wasmBytes);
    resources.add(module);

    final Instance instance = module.instantiate(store);
    resources.add(instance);

    // Check if instance has globals
    final List<Export> exports = instance.getExports();
    final boolean hasGlobalExports =
        exports.stream().anyMatch(export -> export.getType() == Export.Type.GLOBAL);

    if (hasGlobalExports) {
      logger.info("Global access validation passed with global exports found");
    } else {
      logger.info("No global exports found in module, basic validation passed");
    }
  }

  @Test
  @DisplayName("Table Operations")
  void testTableOperations() throws WasmException, IOException {
    final byte[] wasmBytes = loadTableWasmModule();
    final Module module = engine.compileModule(wasmBytes);
    resources.add(module);

    final Instance instance = module.instantiate(store);
    resources.add(instance);

    // Check if instance has tables
    final List<Export> exports = instance.getExports();
    final boolean hasTableExports =
        exports.stream().anyMatch(export -> export.getType() == Export.Type.TABLE);

    if (hasTableExports) {
      logger.info("Table operations validation passed with table exports found");
    } else {
      logger.info("No table exports found in module, basic validation passed");
    }
  }

  @Test
  @DisplayName("Error Handling and Invalid Module")
  void testErrorHandling() {
    // Test compilation with invalid WASM bytes
    final byte[] invalidWasm = {0x00, 0x61, 0x73, 0x6D}; // Incomplete WASM header

    assertThrows(
        WasmException.class,
        () -> {
          engine.compileModule(invalidWasm);
        },
        "Should throw WasmException for invalid module");

    // Test with null input
    assertThrows(
        IllegalArgumentException.class,
        () -> {
          engine.compileModule(null);
        },
        "Should throw IllegalArgumentException for null input");

    logger.info("Error handling validation passed");
  }

  @Test
  @DisplayName("Resource Management and Cleanup")
  void testResourceManagement() throws WasmException, IOException {
    final byte[] wasmBytes = loadSimpleWasmModule();
    final Module module = engine.compileModule(wasmBytes);
    final Instance instance = module.instantiate(store);

    // Verify resources are valid before closing
    assertTrue(module.isValid(), "Module should be valid before closing");
    assertTrue(engine.isValid(), "Engine should be valid");

    // Close instance
    instance.close();

    // Close module
    module.close();

    // Verify cleanup
    assertFalse(module.isValid(), "Module should be invalid after closing");

    logger.info("Resource management validation passed");
  }

  @Test
  @DisplayName("Multiple Instance Creation from Same Module")
  void testMultipleInstances() throws WasmException, IOException {
    final byte[] wasmBytes = loadSimpleWasmModule();
    final Module module = engine.compileModule(wasmBytes);
    resources.add(module);

    // Create multiple instances
    final Instance instance1 = module.instantiate(store);
    resources.add(instance1);

    final Instance instance2 = module.instantiate(store);
    resources.add(instance2);

    assertNotNull(instance1, "First instance should be created");
    assertNotNull(instance2, "Second instance should be created");
    assertNotSame(instance1, instance2, "Instances should be different objects");

    // Verify both instances work independently
    final Function func1 = instance1.getFunction("add");
    final Function func2 = instance2.getFunction("add");

    assertNotNull(func1, "First instance should have 'add' function");
    assertNotNull(func2, "Second instance should have 'add' function");

    final WasmValue[] params = {WasmValue.createI32(10), WasmValue.createI32(20)};
    final WasmValue[] result1 = func1.call(params);
    final WasmValue[] result2 = func2.call(params);

    assertEquals(30, result1[0].getI32(), "First instance should compute correctly");
    assertEquals(30, result2[0].getI32(), "Second instance should compute correctly");

    logger.info("Multiple instance validation passed");
  }

  @Test
  @DisplayName("Engine Feature Support")
  void testEngineFeatures() {
    // Test basic feature support queries
    final boolean supportsThreads = engine.supportsFeature(WasmFeature.THREADS);
    final boolean supportsSimd = engine.supportsFeature(WasmFeature.SIMD);
    final boolean supportsReferenceTypes = engine.supportsFeature(WasmFeature.REFERENCE_TYPES);

    // These are informational - we don't assert specific values since support may vary
    logger.info(
        "Engine feature support - Threads: "
            + supportsThreads
            + ", SIMD: "
            + supportsSimd
            + ", Reference Types: "
            + supportsReferenceTypes);

    // Test engine limits
    final int memoryLimitPages = engine.getMemoryLimitPages();
    final long stackSizeLimit = engine.getStackSizeLimit();
    final boolean fuelEnabled = engine.isFuelEnabled();
    final boolean epochInterruption = engine.isEpochInterruptionEnabled();
    final int maxInstances = engine.getMaxInstances();

    assertTrue(memoryLimitPages >= 0, "Memory limit should be non-negative");
    assertTrue(stackSizeLimit >= 0, "Stack size limit should be non-negative");
    assertTrue(maxInstances >= 0, "Max instances should be non-negative");

    logger.info(
        "Engine limits - Memory: "
            + memoryLimitPages
            + " pages, "
            + "Stack: "
            + stackSizeLimit
            + " bytes, "
            + "Fuel: "
            + fuelEnabled
            + ", "
            + "Epoch: "
            + epochInterruption
            + ", "
            + "MaxInstances: "
            + maxInstances);

    logger.info("Engine feature support validation passed");
  }

  /**
   * Loads a simple WebAssembly module for testing.
   *
   * @return the WebAssembly module bytes
   * @throws IOException if the module cannot be loaded
   */
  private byte[] loadSimpleWasmModule() throws IOException {
    return loadWasmResource("/wasm/simple.wat");
  }

  /**
   * Loads a WebAssembly module with memory for testing.
   *
   * @return the WebAssembly module bytes
   * @throws IOException if the module cannot be loaded
   */
  private byte[] loadMemoryWasmModule() throws IOException {
    // Try to load a module with memory, fallback to simple module
    try {
      return loadWasmResource("/wasm/memory_test.wat");
    } catch (final IOException e) {
      logger.info("Memory test module not found, using simple module");
      return loadSimpleWasmModule();
    }
  }

  /**
   * Loads a WebAssembly module with globals for testing.
   *
   * @return the WebAssembly module bytes
   * @throws IOException if the module cannot be loaded
   */
  private byte[] loadGlobalWasmModule() throws IOException {
    // Try to load a module with globals, fallback to simple module
    try {
      return loadWasmResource("/wasm/global_test.wat");
    } catch (final IOException e) {
      logger.info("Global test module not found, using simple module");
      return loadSimpleWasmModule();
    }
  }

  /**
   * Loads a WebAssembly module with tables for testing.
   *
   * @return the WebAssembly module bytes
   * @throws IOException if the module cannot be loaded
   */
  private byte[] loadTableWasmModule() throws IOException {
    // Try to load a module with tables, fallback to simple module
    try {
      return loadWasmResource("/wasm/table_test.wat");
    } catch (final IOException e) {
      logger.info("Table test module not found, using simple module");
      return loadSimpleWasmModule();
    }
  }

  /**
   * Loads WebAssembly module bytes from a resource.
   *
   * @param resourcePath the path to the resource
   * @return the module bytes
   * @throws IOException if the resource cannot be loaded
   */
  private byte[] loadWasmResource(final String resourcePath) throws IOException {
    try (final InputStream inputStream = getClass().getResourceAsStream(resourcePath)) {
      if (inputStream == null) {
        throw new IOException("Resource not found: " + resourcePath);
      }
      return inputStream.readAllBytes();
    }
  }
}
