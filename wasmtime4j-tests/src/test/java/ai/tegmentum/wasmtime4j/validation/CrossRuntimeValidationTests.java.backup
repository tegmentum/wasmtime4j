package ai.tegmentum.wasmtime4j.validation;

import static org.junit.jupiter.api.Assertions.*;

import ai.tegmentum.wasmtime4j.Engine;
import ai.tegmentum.wasmtime4j.Function;
import ai.tegmentum.wasmtime4j.Instance;
import ai.tegmentum.wasmtime4j.Module;
import ai.tegmentum.wasmtime4j.RuntimeType;
import ai.tegmentum.wasmtime4j.Store;
import ai.tegmentum.wasmtime4j.WasmRuntime;
import ai.tegmentum.wasmtime4j.WasmValue;
import ai.tegmentum.wasmtime4j.comparison.runners.CrossRuntimeTest;
import ai.tegmentum.wasmtime4j.comparison.runners.CrossRuntimeTestSuite;
import ai.tegmentum.wasmtime4j.comparison.runners.OverallValidationResult;
import ai.tegmentum.wasmtime4j.exception.WasmException;
import ai.tegmentum.wasmtime4j.factory.WasmRuntimeFactory;
import java.io.IOException;
import java.io.InputStream;
import java.util.Arrays;
import java.util.List;
import java.util.logging.Logger;
import org.junit.jupiter.api.DisplayName;
import org.junit.jupiter.api.Test;
import org.junit.jupiter.api.condition.EnabledIf;

/**
 * Cross-runtime validation tests comparing JNI and Panama implementations.
 *
 * <p>This test class validates behavioral consistency between JNI and Panama runtime
 * implementations, ensuring they produce identical results for the same WebAssembly operations.
 * Tests leverage the preserved CrossRuntimeTest framework for systematic comparison.
 *
 * @since 1.0.0
 */
@DisplayName("Cross-Runtime Validation Tests")
public final class CrossRuntimeValidationTests {

  private static final Logger logger =
      Logger.getLogger(CrossRuntimeValidationTests.class.getName());

  /** Basic test to ensure both runtimes can be created and perform simple operations. */
  @Test
  @DisplayName("Basic Runtime Availability Check")
  void testRuntimeAvailability() {
    final boolean jniAvailable = WasmRuntimeFactory.isRuntimeAvailable(RuntimeType.JNI);
    final boolean panamaAvailable = WasmRuntimeFactory.isRuntimeAvailable(RuntimeType.PANAMA);

    logger.info("Runtime availability - JNI: " + jniAvailable + ", Panama: " + panamaAvailable);

    // At least one runtime should be available
    assertTrue(
        jniAvailable || panamaAvailable, "At least one runtime implementation should be available");
  }

  /** Test that enabled if both JNI and Panama runtimes are available. */
  @Test
  @EnabledIf("bothRuntimesAvailable")
  @DisplayName("Cross-Runtime Function Call Consistency")
  void testCrossRuntimeFunctionCallConsistency() throws Exception {
    final CrossRuntimeTest functionTest = new BasicFunctionCallTest();

    final Object jniResult = functionTest.execute(RuntimeType.JNI);
    final Object panamaResult = functionTest.execute(RuntimeType.PANAMA);

    assertEquals(
        jniResult, panamaResult, "JNI and Panama implementations should produce identical results");

    logger.info("Cross-runtime function call consistency validated");
  }

  /** Test engine creation consistency across runtimes. */
  @Test
  @EnabledIf("bothRuntimesAvailable")
  @DisplayName("Cross-Runtime Engine Creation Consistency")
  void testCrossRuntimeEngineCreation() throws Exception {
    final CrossRuntimeTest engineTest = new EngineCreationTest();

    final Object jniResult = engineTest.execute(RuntimeType.JNI);
    final Object panamaResult = engineTest.execute(RuntimeType.PANAMA);

    assertNotNull(jniResult, "JNI engine creation should succeed");
    assertNotNull(panamaResult, "Panama engine creation should succeed");

    logger.info("Cross-runtime engine creation consistency validated");
  }

  /** Test module compilation consistency across runtimes. */
  @Test
  @EnabledIf("bothRuntimesAvailable")
  @DisplayName("Cross-Runtime Module Compilation Consistency")
  void testCrossRuntimeModuleCompilation() throws Exception {
    final CrossRuntimeTest compilationTest = new ModuleCompilationTest();

    final Object jniResult = compilationTest.execute(RuntimeType.JNI);
    final Object panamaResult = compilationTest.execute(RuntimeType.PANAMA);

    assertEquals(
        jniResult,
        panamaResult,
        "JNI and Panama implementations should compile modules consistently");

    logger.info("Cross-runtime module compilation consistency validated");
  }

  /** Run a comprehensive test suite across both runtimes. */
  @Test
  @EnabledIf("bothRuntimesAvailable")
  @DisplayName("Comprehensive Cross-Runtime Test Suite")
  void testComprehensiveCrossRuntimeSuite() throws Exception {
    final List<CrossRuntimeTest> tests =
        Arrays.asList(
            new EngineCreationTest(),
            new ModuleCompilationTest(),
            new BasicFunctionCallTest(),
            new MemoryOperationsTest(),
            new ErrorHandlingTest());

    final CrossRuntimeTestSuite testSuite =
        new CrossRuntimeTestSuite(
            "Comprehensive Validation Suite",
            "Validates core WebAssembly operations across JNI and Panama runtimes",
            tests);

    int successfulTests = 0;
    int totalTests = testSuite.getTestCount();

    for (final CrossRuntimeTest test : testSuite.getTests()) {
      try {
        final Object jniResult = test.execute(RuntimeType.JNI);
        final Object panamaResult = test.execute(RuntimeType.PANAMA);

        if (resultsAreConsistent(jniResult, panamaResult)) {
          successfulTests++;
          logger.info("Test '" + test.getName() + "' passed cross-runtime validation");
        } else {
          logger.warning("Test '" + test.getName() + "' failed cross-runtime validation");
        }
      } catch (final Exception e) {
        logger.warning("Test '" + test.getName() + "' threw exception: " + e.getMessage());
      }
    }

    final double consistencyScore = (double) successfulTests / totalTests;
    final OverallValidationResult result =
        new OverallValidationResult.Builder()
            .totalTests(totalTests)
            .totalSuites(1)
            .overallConsistencyScore(consistencyScore)
            .productionReadyTests(successfulTests)
            .meetsProductionRequirements(consistencyScore >= 0.95)
            .achievesZeroDiscrepancy(successfulTests == totalTests)
            .build();

    logger.info("Cross-runtime validation result: " + result);

    // Assert minimum consistency threshold
    assertTrue(
        consistencyScore >= 0.80,
        "Cross-runtime consistency should be at least 80% (actual: "
            + String.format("%.1f", consistencyScore * 100)
            + "%)");
  }

  /** Condition method to check if both runtimes are available. */
  static boolean bothRuntimesAvailable() {
    return WasmRuntimeFactory.isRuntimeAvailable(RuntimeType.JNI)
        && WasmRuntimeFactory.isRuntimeAvailable(RuntimeType.PANAMA);
  }

  /** Check if two results are consistent across runtimes. */
  private boolean resultsAreConsistent(final Object result1, final Object result2) {
    if (result1 == null && result2 == null) {
      return true;
    }
    if (result1 == null || result2 == null) {
      return false;
    }
    return result1.equals(result2);
  }

  /** Test implementation for basic function calls. */
  private static final class BasicFunctionCallTest
      extends CrossRuntimeTest.AbstractCrossRuntimeTest {

    BasicFunctionCallTest() {
      super("Basic Function Call", "Tests basic WebAssembly function invocation");
    }

    @Override
    public Object execute(final RuntimeType runtime) throws Exception {
      WasmRuntimeFactory.clearCache();
      System.setProperty(
          WasmRuntimeFactory.RUNTIME_PROPERTY, runtime == RuntimeType.JNI ? "jni" : "panama");

      try (final WasmRuntime wasmRuntime = WasmRuntimeFactory.create(runtime);
          final Engine engine = wasmRuntime.createEngine();
          final Store store = engine.createStore()) {

        final byte[] wasmBytes = loadSimpleWasmModule();
        final Module module = engine.compileModule(wasmBytes);

        try (module) {
          final Instance instance = module.instantiate(store);

          try (instance) {
            final Function addFunction = instance.getFunction("add");
            final WasmValue[] params = {WasmValue.createI32(5), WasmValue.createI32(3)};
            final WasmValue[] results = addFunction.call(params);

            return results[0].getI32(); // Should return 8
          }
        }
      } finally {
        System.clearProperty(WasmRuntimeFactory.RUNTIME_PROPERTY);
      }
    }
  }

  /** Test implementation for engine creation. */
  private static final class EngineCreationTest extends CrossRuntimeTest.AbstractCrossRuntimeTest {

    EngineCreationTest() {
      super("Engine Creation", "Tests WebAssembly engine creation");
    }

    @Override
    public Object execute(final RuntimeType runtime) throws Exception {
      WasmRuntimeFactory.clearCache();
      System.setProperty(
          WasmRuntimeFactory.RUNTIME_PROPERTY, runtime == RuntimeType.JNI ? "jni" : "panama");

      try (final WasmRuntime wasmRuntime = WasmRuntimeFactory.create(runtime);
          final Engine engine = wasmRuntime.createEngine()) {

        return engine.isValid() ? "valid" : "invalid";
      } finally {
        System.clearProperty(WasmRuntimeFactory.RUNTIME_PROPERTY);
      }
    }
  }

  /** Test implementation for module compilation. */
  private static final class ModuleCompilationTest
      extends CrossRuntimeTest.AbstractCrossRuntimeTest {

    ModuleCompilationTest() {
      super("Module Compilation", "Tests WebAssembly module compilation");
    }

    @Override
    public Object execute(final RuntimeType runtime) throws Exception {
      WasmRuntimeFactory.clearCache();
      System.setProperty(
          WasmRuntimeFactory.RUNTIME_PROPERTY, runtime == RuntimeType.JNI ? "jni" : "panama");

      try (final WasmRuntime wasmRuntime = WasmRuntimeFactory.create(runtime);
          final Engine engine = wasmRuntime.createEngine()) {

        final byte[] wasmBytes = loadSimpleWasmModule();
        final Module module = engine.compileModule(wasmBytes);

        try (module) {
          return module.isValid() ? "compiled" : "failed";
        }
      } finally {
        System.clearProperty(WasmRuntimeFactory.RUNTIME_PROPERTY);
      }
    }
  }

  /** Test implementation for memory operations. */
  private static final class MemoryOperationsTest
      extends CrossRuntimeTest.AbstractCrossRuntimeTest {

    MemoryOperationsTest() {
      super("Memory Operations", "Tests WebAssembly memory operations");
    }

    @Override
    public Object execute(final RuntimeType runtime) throws Exception {
      WasmRuntimeFactory.clearCache();
      System.setProperty(
          WasmRuntimeFactory.RUNTIME_PROPERTY, runtime == RuntimeType.JNI ? "jni" : "panama");

      try (final WasmRuntime wasmRuntime = WasmRuntimeFactory.create(runtime);
          final Engine engine = wasmRuntime.createEngine();
          final Store store = engine.createStore()) {

        final byte[] wasmBytes = loadSimpleWasmModule();
        final Module module = engine.compileModule(wasmBytes);

        try (module) {
          final Instance instance = module.instantiate(store);

          try (instance) {
            // For simple module, just verify instance creation
            return "memory_accessible";
          }
        }
      } finally {
        System.clearProperty(WasmRuntimeFactory.RUNTIME_PROPERTY);
      }
    }
  }

  /** Test implementation for error handling. */
  private static final class ErrorHandlingTest extends CrossRuntimeTest.AbstractCrossRuntimeTest {

    ErrorHandlingTest() {
      super("Error Handling", "Tests WebAssembly error handling consistency");
    }

    @Override
    public Object execute(final RuntimeType runtime) throws Exception {
      WasmRuntimeFactory.clearCache();
      System.setProperty(
          WasmRuntimeFactory.RUNTIME_PROPERTY, runtime == RuntimeType.JNI ? "jni" : "panama");

      try (final WasmRuntime wasmRuntime = WasmRuntimeFactory.create(runtime);
          final Engine engine = wasmRuntime.createEngine()) {

        // Test with invalid WASM bytes
        final byte[] invalidWasm = {0x00, 0x61, 0x73, 0x6D}; // Incomplete header

        try {
          engine.compileModule(invalidWasm);
          return "no_error"; // Should not reach here
        } catch (final WasmException e) {
          return "expected_error";
        }
      } finally {
        System.clearProperty(WasmRuntimeFactory.RUNTIME_PROPERTY);
      }
    }
  }

  /** Loads simple WebAssembly module bytes. */
  private static byte[] loadSimpleWasmModule() throws IOException {
    try (final InputStream inputStream =
        CrossRuntimeValidationTests.class.getResourceAsStream("/wasm/simple.wat")) {
      if (inputStream == null) {
        throw new IOException("Simple WASM module not found");
      }
      return inputStream.readAllBytes();
    }
  }
}
