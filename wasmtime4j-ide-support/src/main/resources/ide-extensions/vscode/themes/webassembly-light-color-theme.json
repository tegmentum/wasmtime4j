{
    "name": "WebAssembly Light",
    "type": "light",
    "colors": {
        "editor.background": "#ffffff",
        "editor.foreground": "#000000",
        "editor.selectionBackground": "#add6ff",
        "editor.lineHighlightBackground": "#f0f0f0",
        "editor.findMatchBackground": "#a8ac94",
        "editor.findMatchHighlightBackground": "#ea5c0066",
        "editor.findRangeHighlightBackground": "#b4b4b44d",
        "editorCursor.foreground": "#000000",
        "editorWhitespace.foreground": "#bfbfbf",
        "editorIndentGuide.background": "#d3d3d3",
        "editorIndentGuide.activeBackground": "#939393",
        "editorLineNumber.foreground": "#237893",
        "editorLineNumber.activeForeground": "#0b216f"
    },
    "tokenColors": [
        {
            "name": "Comments",
            "scope": [
                "comment",
                "punctuation.definition.comment"
            ],
            "settings": {
                "fontStyle": "italic",
                "foreground": "#008000"
            }
        },
        {
            "name": "WebAssembly Keywords",
            "scope": [
                "keyword.control.wat",
                "keyword.other.wat"
            ],
            "settings": {
                "foreground": "#0000FF"
            }
        },
        {
            "name": "WebAssembly Types",
            "scope": [
                "storage.type.wat"
            ],
            "settings": {
                "foreground": "#267F99"
            }
        },
        {
            "name": "WebAssembly Instructions - Arithmetic",
            "scope": [
                "support.function.arithmetic.wat"
            ],
            "settings": {
                "foreground": "#795E26"
            }
        },
        {
            "name": "WebAssembly Instructions - Memory",
            "scope": [
                "support.function.memory.wat",
                "support.function.memory-size.wat"
            ],
            "settings": {
                "foreground": "#0000FF"
            }
        },
        {
            "name": "WebAssembly Instructions - Conversion",
            "scope": [
                "support.function.conversion.wat"
            ],
            "settings": {
                "foreground": "#A31515"
            }
        },
        {
            "name": "WebAssembly Instructions - SIMD",
            "scope": [
                "support.function.simd.wat"
            ],
            "settings": {
                "foreground": "#D73A49"
            }
        },
        {
            "name": "WebAssembly Instructions - Table",
            "scope": [
                "support.function.table.wat"
            ],
            "settings": {
                "foreground": "#22863A"
            }
        },
        {
            "name": "WebAssembly Instructions - Reference",
            "scope": [
                "support.function.reference.wat"
            ],
            "settings": {
                "foreground": "#E36209"
            }
        },
        {
            "name": "WebAssembly Numbers",
            "scope": [
                "constant.numeric.integer.wat",
                "constant.numeric.integer.hexadecimal.wat",
                "constant.numeric.float.wat",
                "constant.numeric.float.hexadecimal.wat",
                "constant.numeric.float.special.wat"
            ],
            "settings": {
                "foreground": "#098658"
            }
        },
        {
            "name": "WebAssembly Identifiers",
            "scope": [
                "variable.other.identifier.wat"
            ],
            "settings": {
                "foreground": "#001080"
            }
        },
        {
            "name": "WebAssembly Strings",
            "scope": [
                "string.quoted.double.wat"
            ],
            "settings": {
                "foreground": "#A31515"
            }
        },
        {
            "name": "WebAssembly String Escapes",
            "scope": [
                "constant.character.escape.wat"
            ],
            "settings": {
                "foreground": "#EE0000"
            }
        },
        {
            "name": "WebAssembly Parentheses",
            "scope": [
                "punctuation.section.parens.wat"
            ],
            "settings": {
                "foreground": "#800080"
            }
        }
    ]
}