{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "WebAssembly Text",
    "patterns": [
        {"include": "#comments"},
        {"include": "#keywords"},
        {"include": "#types"},
        {"include": "#instructions"},
        {"include": "#literals"},
        {"include": "#identifiers"},
        {"include": "#strings"},
        {"include": "#parentheses"}
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "name": "comment.line.double-semicolon.wat",
                    "match": ";;.*$"
                },
                {
                    "name": "comment.block.wat",
                    "begin": "\\(;",
                    "end": ";\\)",
                    "patterns": [
                        {"include": "#comments"}
                    ]
                }
            ]
        },
        "keywords": {
            "patterns": [
                {
                    "name": "keyword.control.wat",
                    "match": "\\b(module|func|export|import|param|result|local|global|table|memory|type|start|elem|data|if|then|else|end|loop|block|br|br_if|br_table|call|call_indirect|return|unreachable|nop|drop|select)\\b"
                },
                {
                    "name": "keyword.other.wat",
                    "match": "\\b(mut|shared|const)\\b"
                }
            ]
        },
        "types": {
            "patterns": [
                {
                    "name": "storage.type.wat",
                    "match": "\\b(i32|i64|f32|f64|v128|funcref|externref|anyref|nullref)\\b"
                }
            ]
        },
        "instructions": {
            "patterns": [
                {
                    "name": "support.function.arithmetic.wat",
                    "match": "\\b(i32|i64|f32|f64|v128)\\.(add|sub|mul|div_[su]|rem_[su]|and|or|xor|shl|shr_[su]|rotl|rotr|clz|ctz|popcnt|eqz|eq|ne|lt_[su]|gt_[su]|le_[su]|ge_[su]|abs|neg|ceil|floor|trunc|nearest|sqrt|min|max|copysign)\\b"
                },
                {
                    "name": "support.function.memory.wat",
                    "match": "\\b(i32|i64|f32|f64)\\.(load|store)(8_[su]|16_[su]|32_[su])?\\b"
                },
                {
                    "name": "support.function.conversion.wat",
                    "match": "\\b(i32|i64|f32|f64)\\.(wrap|extend|trunc|convert|demote|promote|reinterpret)_(i32|i64|f32|f64)(_[su])?\\b"
                },
                {
                    "name": "support.function.simd.wat",
                    "match": "\\bv128\\.(load|store|const|not|and|andnot|or|xor|bitselect|any_true|extract_lane|replace_lane|splat|eq|ne|lt|le|gt|ge|add|sub|mul|min|max|avg|abs|neg|sqrt|ceil|floor|trunc|nearest)\\b"
                },
                {
                    "name": "support.function.memory-size.wat",
                    "match": "\\bmemory\\.(size|grow)\\b"
                },
                {
                    "name": "support.function.table.wat",
                    "match": "\\btable\\.(get|set|size|grow|fill|copy|init)\\b"
                },
                {
                    "name": "support.function.reference.wat",
                    "match": "\\b(ref\\.(null|is_null|func)|table\\.(get|set))\\b"
                }
            ]
        },
        "literals": {
            "patterns": [
                {
                    "name": "constant.numeric.integer.wat",
                    "match": "\\b-?[0-9][0-9_]*\\b"
                },
                {
                    "name": "constant.numeric.integer.hexadecimal.wat",
                    "match": "\\b-?0x[0-9a-fA-F][0-9a-fA-F_]*\\b"
                },
                {
                    "name": "constant.numeric.float.wat",
                    "match": "\\b-?[0-9][0-9_]*\\.[0-9_]*([eE][+-]?[0-9_]+)?\\b"
                },
                {
                    "name": "constant.numeric.float.hexadecimal.wat",
                    "match": "\\b-?0x[0-9a-fA-F][0-9a-fA-F_]*\\.[0-9a-fA-F_]*([pP][+-]?[0-9_]+)?\\b"
                },
                {
                    "name": "constant.numeric.float.special.wat",
                    "match": "\\b(inf|nan)\\b"
                }
            ]
        },
        "identifiers": {
            "patterns": [
                {
                    "name": "variable.other.identifier.wat",
                    "match": "\\$[a-zA-Z_][a-zA-Z0-9_]*"
                }
            ]
        },
        "strings": {
            "patterns": [
                {
                    "name": "string.quoted.double.wat",
                    "begin": "\"",
                    "end": "\"",
                    "patterns": [
                        {
                            "name": "constant.character.escape.wat",
                            "match": "\\\\(n|t|r|\\\\|\"|'|[0-9a-fA-F]{2})"
                        }
                    ]
                }
            ]
        },
        "parentheses": {
            "patterns": [
                {
                    "name": "punctuation.section.parens.wat",
                    "match": "[()\\[\\]{}]"
                }
            ]
        }
    },
    "scopeName": "source.wat"
}