<?xml version="1.0" encoding="UTF-8"?>
<FindBugsFilter>
  <!-- Suppress unread field warnings for WASI experimental data classes -->
  <!-- These are data classes where fields are accessed by native code, reflection, or reserved for future use -->
  <Match>
    <Bug pattern="URF_UNREAD_PUBLIC_OR_PROTECTED_FIELD"/>
    <Or>
      <Class name="~.*\.wasi\..*\$.*"/>
      <Class name="~.*\.memory\..*\$.*"/>
    </Or>
  </Match>

  <!-- Suppress command injection in WasiProcessOperations.spawnProcess() -->
  <!-- ProcessBuilder with List<String> is safe - does not invoke shell, arguments passed separately to OS -->
  <Match>
    <Bug pattern="COMMAND_INJECTION"/>
    <Class name="ai.tegmentum.wasmtime4j.panama.wasi.WasiProcessOperations"/>
    <Or>
      <Method name="spawnProcess"/>
      <Method name="~lambda\$spawnProcess.*"/>
    </Or>
  </Match>

  <!-- Suppress singleton getter not synchronized warning in PanamaOptimizationEngine -->
  <!-- Double-checked locking with explicit Lock is safe and performant -->
  <Match>
    <Bug pattern="SING_SINGLETON_GETTER_NOT_SYNCHRONIZED"/>
    <Class name="ai.tegmentum.wasmtime4j.panama.performance.PanamaOptimizationEngine"/>
  </Match>

  <!-- Suppress overridable method call in PanamaResource constructor -->
  <!-- getClass() is final and cannot be overridden, this is a false positive -->
  <Match>
    <Bug pattern="MC_OVERRIDABLE_METHOD_CALL_IN_CONSTRUCTOR"/>
    <Class name="ai.tegmentum.wasmtime4j.panama.PanamaResource"/>
  </Match>

  <!-- Suppress System.exit() warning in WasiProcessOperations.raiseSignal -->
  <!-- This method explicitly simulates signal handling which may require process termination -->
  <Match>
    <Bug pattern="DM_EXIT"/>
    <Class name="ai.tegmentum.wasmtime4j.panama.wasi.WasiProcessOperations"/>
  </Match>

  <!-- Suppress test-specific warnings in test classes -->
  <!-- Tests intentionally use patterns that trigger warnings for validation purposes -->
  <Match>
    <Or>
      <Bug pattern="CNT_ROUGH_CONSTANT_VALUE"/>
      <Bug pattern="NP_NONNULL_PARAM_VIOLATION"/>
      <Bug pattern="DE_MIGHT_IGNORE"/>
    </Or>
    <Class name="~.*Test.*"/>
  </Match>
</FindBugsFilter>
