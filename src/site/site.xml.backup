<?xml version="1.0" encoding="UTF-8"?>
<project name="Wasmtime4j" 
         xmlns="http://maven.apache.org/DECORATION/1.8.0" 
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/DECORATION/1.8.0 
                             https://maven.apache.org/xsd/decoration-1.8.0.xsd">

  <custom>
    <fluidoSkin>
      <topBarEnabled>true</topBarEnabled>
      <sideBarEnabled>true</sideBarEnabled>
      <searchEnabled>true</searchEnabled>
      <gitHub>
        <projectId>tegmentum/wasmtime4j</projectId>
        <ribbonOrientation>right</ribbonOrientation>
        <ribbonColor>black</ribbonColor>
      </gitHub>
      <twitter>
        <user>wasmtime4j</user>
        <showUser>false</showUser>
        <showFollowers>false</showFollowers>
      </twitter>
      <plusOne>false</plusOne>
      <facebookLike>false</facebookLike>
      <sourceLineNumbersEnabled>true</sourceLineNumbersEnabled>
    </fluidoSkin>
  </custom>

  <bannerLeft>
    <name>Wasmtime4j</name>
    <alt>Wasmtime4j</alt>
    <href>https://wasmtime4j.tegmentum.ai/</href>
  </bannerLeft>

  <version position="right"/>

  <publishDate position="right" format="yyyy-MM-dd"/>

  <skin>
    <groupId>org.apache.maven.skins</groupId>
    <artifactId>maven-fluido-skin</artifactId>
    <version>1.11.1</version>
  </skin>

