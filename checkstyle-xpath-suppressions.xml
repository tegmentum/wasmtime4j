<?xml version="1.0"?>
<!DOCTYPE suppressions PUBLIC
    "-//Checkstyle//DTD SuppressionXpathFilter Experimental Configuration 1.2//EN"
    "https://checkstyle.org/dtds/suppressionxpathfilter_1_2.dtd">

<suppressions>
    <!-- Allow IT suffix for integration test classes -->
    <suppress-xpath checks="AbbreviationAsWordInName" 
                    query="//CLASS_DEF[contains(@text, 'IT')]" />
    
    <!-- Allow common abbreviations in test files -->
    <suppress-xpath checks="AbbreviationAsWordInName" 
                    query="//METHOD_DEF[contains(@text, 'MacOS') or contains(@text, 'ARM64') or contains(@text, 'OS')]" />
    
    <!-- Allow variable names with OS/ARM64 in test utilities -->
    <suppress-xpath checks="AbbreviationAsWordInName"
                    query="//VARIABLE_DEF[contains(@text, 'MacOS') or contains(@text, 'ARM64') or contains(@text, 'OS')]" />

    <!-- Suppress all indentation checks in comparison tests module (test/utility code) -->
    <suppress-xpath checks="Indentation"
                    query="//*"
                    files=".*wasmtime4j-comparison-tests.*" />

    <!-- Suppress Javadoc requirements for test methods in wasmtime-tests module -->
    <!-- Test methods use @DisplayName annotations which serve the documentation purpose -->
    <suppress-xpath checks="MissingJavadocMethod"
                    query="//METHOD_DEF[.//ANNOTATION/IDENT[@text='ParameterizedTest' or @text='Test' or @text='DisplayName']]"
                    files=".*wasmtime4j-wasmtime-tests.*" />
</suppressions>